<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hotel Reservation" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="header">
      <div class="logo">
        <%= link_to 'Resevation.com', root_path %>
      </div>

      <nav class="nav">
        <% if current_user %>
          <div class="user-menu">
            <div class="user-menu-button" id="userMenuButton">
              <% if current_user.icon.attached? %>
                <%= image_tag current_user.icon, class: "user-icon" %>
              <% else %>
                <%= image_tag "default_icon.png", class: "user-icon" %>
              <% end %>
              <span class="user-name-nav"><%= current_user.name %></span>
            </div>

            <div class="hamburger-menu" id="userMenu">
              <%= link_to '予約一覧', reservations_path, class: "nav-link" %>
              <%= link_to '施設一覧', rooms_path, class: "nav-link" %>
              <%= link_to '新規施設登録', new_room_path, class: "nav-link" %>
              <%= link_to 'マイページ', user_path(current_user), class: "nav-link" %>
              <%= link_to 'ログアウト', session_path, data: { turbo_method: :delete }, class: "nav-link", onclick: "return confirm('ログアウトしますか？');" %>
            </div>
          </div>
        <% else %>
          <div class="guest-menu">
            <div class="hamburger-button" id="guestMenuButton">
              ☰
            </div>
            <div class="hamburger-menu-guest" id="guestMenu">
              <%= link_to 'ログイン', new_session_path, class: 'nav-link' %>
              <%= link_to '新規登録', new_user_path, class: 'nav-link' %>
            </div>
          </div>
        <% end %>
      </nav>

    </header>
    <% if flash[:notice] %>
      <p class="flash-notice"><%= flash[:notice] %></p>
    <% end %>
    <% if flash[:alert] %>
      <p class="flash-alert"><%= flash[:alert] %></p>
    <% end %>
    <%= yield %>
  </body>
</html>
