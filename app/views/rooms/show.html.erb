<div class="room-detail-container">
  <div class="room-detail-header">
    <button type="button" class="back-button" onclick="window.history.back()">
      <span class="arrow">←</span>  
    </button>
    <h1><%= @room.name %></h1>
  </div>

  
  <div class="room-detail-content">
    <div class="room-detail-info">
      <% if @room.images.attached? %>
        <div class="room-images-gallery">
          <% @room.images.each do |image| %>
            <%= image_tag image, class: 'room-image' %>
          <% end %>
        </div>
      <% end %>

      <div class="info-item">
        <span class="info-label">説明</span>
        <p class="info-value"><%= simple_format(@room.description) %></p>
      </div>

      <div class="info-item">
        <span class="info-label">住所</span>
        <p class="info-value"><%= @room.address %></p>

        <div class="map-container">
          <iframe
            width="100%"
            height="300"
            style="border:0"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            src="https://www.google.com/maps?q=<%= URI.encode_www_form_component(@room.address) %>&output=embed">
          </iframe>
        </div>
      </div>

      <div class="info-item">
        <span class="info-label">価格</span>
        <p class="info-value price"><%= number_with_delimiter(@room.price) %>円 / 泊</p>
      </div>
    </div>

    <div class="room-detail-actions">
      <% if current_user == @room.user %>
        <%= link_to '編集', edit_room_path(@room), class: 'btn btn-edit' %>
        <%= link_to '削除', room_path(@room), data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか?' }, class: 'btn btn-delete' %>
      <% else %>
        <%= link_to '予約する', new_room_reservation_path(@room), class: 'btn btn-reserve' %>
      <% end %>
    </div>
  </div>
</div>
