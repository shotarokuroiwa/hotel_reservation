<%= form_with url: searches_path, method: :get, class: 'search-form' do |form| %>
  <div class="form-group">
    <%= form.text_field :area, placeholder: 'エリアを入力' %>
  </div>

  <div class="form-group">
    <%= form.text_field :keyword, placeholder: 'キーワードを入力' %>
  </div>

  <div class="form-group">
    <%= form.submit '検索', class: 'btn btn-search' %>
  </div>
<% end %>

<% if @rooms %>
<h2>検索結果</h2>
<div class=facility-wrapper>
  <p><%= @count.to_i %>件</p>
    <div class="grid-container">
      <% @rooms.each do |room| %>
        <%= link_to room_path(room), class: 'card-link' do %>
          <div class="card">
            <% if room.images.attached? %>
              <%= image_tag room.images.first, class: 'card-image' %>
            <% end %>
            <div class="card-content">
              <h3><%= room.name %></h3>
              <p class=card-content-address><%= room.address %></p>
              <p><%= number_with_delimiter(room.price) %>円 / 泊</p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
