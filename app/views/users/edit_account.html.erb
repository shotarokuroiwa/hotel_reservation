<h1>アカウント情報の変更</h1>

<% if @user.errors.any? %>
  <div id="error_explanation" class="flash-alert">
    <h2>更新時に<%= @user.errors.count %>件のエラーが発生しました:</h2>
    <ul>
      <% @user.errors.each do |error| %>
        <li><%= error.full_message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @user, url: user_path(@user), data: { turbo: false } do |form| %>
  <%= hidden_field_tag :edit_type, "account" %>

  <div>
    <%= form.label :email, 'メールアドレス' %>
    <%= form.email_field :email %>
  </div>

  <div>
    <%= form.label :current_password, '現在のパスワード' %>
    <%= form.password_field :current_password %>
  </div>

  <div>
    <%= form.label :password, '新しいパスワード' %>
    <%= form.password_field :password %>
  </div>

  <div>
    <%= form.label :password_confirmation, '新しいパスワード（確認）' %>
    <%= form.password_field :password_confirmation %>
  </div>

  <div>
    <%= form.submit '更新', class: 'btn btn-primary' %>
  </div>
<% end %>
