<h1 class="page-title">予約確定</h1>

<div class="container">
  <div class="card reservation-card">
    <h2 class="card-title">予約内容</h2>

    <div class="room-info">
      <p><strong>施設名:</strong> <%= @room.name %></p>
      <p><strong>料金:</strong> ¥<%= number_with_delimiter(@room.price) %> / 泊</p>
    </div>

    <div class="room-info">
      <p><strong>チェックイン日:</strong> <%= l(@reservation.check_in) %></p>
      <p><strong>チェックアウト日:</strong> <%= l(@reservation.check_out) %></p>
      <p><strong>宿泊日数:</strong> <%= @stay_days %> 泊</p>
      <p><strong>人数:</strong> <%= @reservation.people %> 名</p>
      <p><strong>支払い金額:</strong> ¥<%= number_with_delimiter(@total_price) %></p>
    </div>

    <%= form_with model: [@room, @reservation],
                  url: room_reservation_path(@room),
                  method: :post,
                  data: { turbo: false } do |form| %>
      <%= form.hidden_field :check_in %>
      <%= form.hidden_field :check_out %>
      <%= form.hidden_field :people %>

      <div class="form-actions">
        <%= link_to "修正する",
                    new_room_reservation_path(@room, reservation: { check_in: @reservation.check_in, check_out: @reservation.check_out, people: @reservation.people }),
                    class: "btn btn-secondary" %>
        <%= form.submit "この内容で予約する", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

