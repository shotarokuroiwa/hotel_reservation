<h1 class="page-title">予約作成</h1>

<div class="container">

  <div class="card room-card">
    <h2 class="card-title"><%= @room.name %></h2>

    <div class="room-info">
      <p><strong>住所:</strong> <%= @room.address %></p>
      <p><strong>料金:</strong> ¥<%= number_with_delimiter(@room.price) %> / 泊</p>
    </div>

    <div class="room-description">
      <p><%= simple_format(@room.description) %></p>
    </div>
  </div>

  <% if @reservation.errors.any? %>
    <div class="flash-alert">
      <h3>予約の確定時に<%= @reservation.errors.count %>件のエラーが発生しました</h3>
      <ul>
        <% @reservation.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card reservation-card">
    <h2 class="card-title">予約内容</h2>

    <%= form_with model: [@room, @reservation],
                  url: confirm_room_reservation_path(@room),
                  method: :post,
                  data: { turbo: false } do |form| %>

      <div class="form-group-reservation">
        <%= form.label :check_in, 'チェックイン' %>
        <%= form.date_field :check_in %>
      </div>

      <div class="form-group-reservation">
        <%= form.label :check_out, 'チェックアウト' %>
        <%= form.date_field :check_out %>
      </div>

      <div class="form-group-reservation">
        <%= form.label :people, '人数' %>
        <%= form.number_field :people, min: 1 %>
      </div>

      <%= form.submit '確定画面へ', class: 'btn btn-primary' %>
    <% end %>
  </div>

</div>
