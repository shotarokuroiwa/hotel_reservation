<h1>予約一覧</h1>
<div class=facility-wrapper>
  <p><%= @count.to_i %>件</p>
  <div class="grid-container">
    <% @reservations.each do |reservation| %>
      <%= link_to reservation_path(reservation), class: "card-link" do %>
        <div class="card">
          <% if reservation.room.images.attached? %>
            <%= image_tag reservation.room.images.first, class: 'card-image' %>
          <% end %>
          <div class="card-content">
            <h3><%= reservation.room.name %></h3>
            <p class="card-description reservation-description"><%= reservation.room.description %></p>
            <p>チェックイン: <%= l(reservation.check_in) %></p>
            <p>チェックアウト: <%= l(reservation.check_out) %></p>
            <p>予約確定日: <%= l(reservation.created_at) %></p>
            <p>人数: <%= reservation.people %>名</p>
            <p class="card-price">合計金額: <%= number_with_delimiter(reservation.total_price) %>円</p>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
